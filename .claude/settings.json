{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/op-guard.ps1\"",
            "timeout": 15,
            "statusMessage": "op-guard: checking for secret-print"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/verify-ps1.ps1\"",
            "timeout": 60,
            "statusMessage": "Verifying .ps1 (parse + SelfTest)"
          }
        ]
      }
    ]
  }
}
